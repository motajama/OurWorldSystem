{
	"name": "ourworldsystem",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"geo:build": "bash scripts/geo/build-natural-earth.sh",
		"registry:seed": "node scripts/data/seed-map-unit-registry-from-natural-earth.mjs",
		"registry:review": "node scripts/validate/registry-review-report.mjs",
		"data:fetch:worldbank": "node scripts/data/fetch-world-bank-wdi.mjs",
		"data:fetch:ucdp": "node scripts/data/fetch-ucdp-conflicts.mjs",
		"data:import:complexity": "node scripts/data/import-atlas-economic-complexity.mjs",
		"data:build:worldsystem": "node scripts/data/build-provisional-world-system.mjs",
		"data:build:worldsystem:structural": "node scripts/data/build-world-system-structural-v1.mjs",
		"data:build": "npm run data:fetch:worldbank && (npm run data:fetch:ucdp || true) && npm run data:build:worldsystem",
		"data:coverage": "node scripts/data/build-map-unit-coverage.mjs",
		"health:data": "node scripts/validate/data-healthcheck.mjs",
		"validate:render-coverage": "node scripts/validate/validate-render-coverage.mjs",
		"validate:map-colors": "node scripts/validate/validate-map-layer-colors.mjs",
		"validate:worldsystem": "node scripts/validate/validate-world-system-provisional.mjs",
		"validate:worldsystem:structural": "node scripts/validate/validate-world-system-structural-v1.mjs",
		"validate:productive-complexity": "node scripts/validate/validate-productive-complexity.mjs",
		"validate:data": "node scripts/validate/validate-map-units.mjs && npm run validate:render-coverage && npm run validate:map-colors && node scripts/validate/validate-indicators.mjs && npm run validate:worldsystem && npm run validate:productive-complexity && node scripts/validate/validate-conflict-indicators.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/d3": "^7.4.3",
		"@types/node": "^24",
		"@types/topojson-client": "^3.1.5",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mapshaper": "^0.7.27",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"d3": "^7.9.0",
		"topojson-client": "^3.1.0"
	},
	"overrides": {
		"@emnapi/core": "1.11.1",
		"@emnapi/runtime": "1.11.1"
	}
}
